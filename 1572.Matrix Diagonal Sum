class Solution {
    public int diagonalSum(int[][] mat) {
        int sum=0,n=mat.length;
for(int i=0;i<n;i++){
    for(int j=0;j<n;j++){
        if(i==j||i+j==n-1){
            sum+=mat[i][j];
        }
    }
}
        
        return sum;
        
    }
}

